# Variables del simulador de Noctua.
# Copiá este archivo a scripts/.env y completá los valores.

# URL base de la API. En local apunta al Laravel del docker-compose.
NOCTUA_API_URL=http://localhost:8000/api

# API key del servicio que va a recibir las métricas. Se obtiene al crear
# un servicio vía POST /api/services (campo "api_key" de la respuesta).
# IMPORTANTE: esta key no se vuelve a mostrar después de la creación.
NOCTUA_API_KEY=